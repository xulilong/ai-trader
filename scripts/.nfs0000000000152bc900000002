#!/bin/bash
# 股票数据自动更新守护进程

REPO_DIR="/tmp/stock-monitor-repo"
DATA_SOURCE="/home/node/.openclaw/workspace/web/data/stock-monitor-data.json"
DATA_DEST="$REPO_DIR/data/stock-monitor-data.json"
LOG_FILE="/tmp/stock-update.log"
GITHUB_TOKEN="${GITHUB_TOKEN:-}"  # 从环境变量获取

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

log "🚀 股票数据自动更新服务启动"

while true; do
    log "⏰ 开始检查数据更新..."
    
    # 检查仓库是否存在
    if [ ! -d "$REPO_DIR" ]; then
        log "📦 克隆仓库..."
        if [ -n "$GITHUB_TOKEN" ]; then
            git clone "https://${GITHUB_TOKEN}@github.com/xulilong/stock-monitor.git" "$REPO_DIR" >> "$LOG_FILE" 2>&1
        else
            git clone git@github.com:xulilong/stock-monitor.git "$REPO_DIR" >> "$LOG_FILE" 2>&1
        fi
    fi
    
    cd "$REPO_DIR"
    
    # 拉取最新代码
    git pull origin main >> "$LOG_FILE" 2>&1 || true
    
    # 复制最新数据
    cp "$DATA_SOURCE" "$DATA_DEST"
    
    # 提交并推送
    git config user.email "bot@openclaw.local"
    git config user.name "OpenClaw Bot"
    git add .
    
    if ! git diff --cached --quiet; then
        git commit -m "📊 自动更新股票数据 - $(date '+%Y-%m-%d %H:%M:%S')" >> "$LOG_FILE" 2>&1
        git push origin main >> "$LOG_FILE" 2>&1
        log "✅ 数据更新成功"
    else
        log "ℹ️  数据无变化，跳过更新"
    fi
    
    # 等待 5 分钟
    log "😴 等待 5 分钟后再次检查..."
    sleep 300
done
